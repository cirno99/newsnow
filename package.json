{
  "name": "newsnow",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "newsnow": "./dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun src/cli.ts",
    "start-tui": "bun src/tui.ts",
    "test": "bun test",
    "build": "tsc",
    "build-bin": "bun build src/tui.ts --compile --minify --sourcemap --bytecode --target=bun-linux-x64-modern --outfile bin/newsnow",
    "release": "bun run build && npm publish"
  },
  "dependencies": {
    "@rezi-ui/core": "0.1.0-alpha.55",
    "@rezi-ui/node": "0.1.0-alpha.55",
    "ansis": "^4.2.0",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.0",
    "iconv-lite": "^0.6.3",
    "ofetch": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
